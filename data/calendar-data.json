  "challenge": {
    "thema_prefix": "",
    "thema_em": "6月は「梅雨の季節」",
    "thema_desc": "6月は、暖かい空気と冷たい空気が日本列島付近でぶつかります。この境目にできるのが「梅雨前線」です。",
    "mission_html": "地域によって、梅雨入りの時期も、天気も大きく変わります。 温度の違いと雨の振り方をデータで観測すると、「梅雨前線」見えてきます。 各地のスクーミースポットを繋いで「梅雨前線の把握」をしてみよう。",
    "mission_note": ""
  },
  "message": {
    "advisor": {
      "icon": "K",
      "role": "顧問",
      "name": "カズ先生",
      "lang": "ja",
      "text": "６月をどう乗り越えるかで、今年前半の質が変わります！蒸し蒸しして過ごしにくい日々かもしれませんが、心はカラッと、いつでもワクワクドキドキを！私はいつでも放課後スクーミー部で待ってますよ！"
    },
    "coach": {
      "icon": "M",
      "role": "コーチ",
      "name": "マット先生",
      "lang": "en",
      "text": "Technology becomes truly interesting when we use it to explore the real world. Let’s use sensors, programming, and creativity to discover new ideas and build something unique together!"
    }
  },
